@page "/attendance"
@page "/homework"
@page "/fees"
@page "/messages"
@page "/admissions"
@page "/notices"
@page "/student-login"
@page "/teacher-login"
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject SchoolContentService Content
@inject PortalSessionService PortalSession
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

@{
    var school = Content.GetProfile();
    var slug = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
    var title = slug switch
    {
        "attendance" => "Attendance",
        "homework" => "Homework",
        "fees" => "Fees",
        "messages" => "Messages",
        "admissions" => "Admissions",
        "notices" => "Notices",
        "student-login" => "Student Login",
        "teacher-login" => "Teacher Login",
        _ => "School Portal"
    };

    var intro = slug switch
    {
        "student-login" => "Student portal modules for academic content, timetable, curriculum, assignments, school details, and progress tracking.",
        "teacher-login" => "Teacher portal modules for student academic data plus school maintenance, administration, communication, and management tasks.",
        "admissions" => "Submit a full admission application and the school team will contact you with the next steps.",
        _ => "This module is scaffolded for the production workflow. Connect it to your database and role-based login to enable live records for parents, students, teachers, and administrators."
    };

    var roleModules = slug switch
    {
        "student-login" => school.StudentModules,
        "teacher-login" => school.TeacherModules,
        _ => []
    };

    var requiresAuthentication = roleModules.Count > 0;
    var portalRole = slug == "teacher-login" ? PortalRoles.Teacher : PortalRoles.Student;
    var isPortalAuthenticated = !requiresAuthentication || PortalSession.IsAuthenticated(portalRole);
    var activePortalSession = PortalSession.GetActiveSession();
    var hasRoleMismatch = requiresAuthentication && activePortalSession is not null && activePortalSession.Role != portalRole;
}

<PageTitle>@title - @school.Name</PageTitle>

<section class="feature-page">
    @if (!requiresAuthentication)
    {
        <div class="feature-hero @(slug == "admissions" ? "admissions-hero" : string.Empty)">
            <a class="back-link back-link-icon" href="/#top" aria-label="Back to dashboard">
                <span class="bi bi-arrow-left" aria-hidden="true"></span>
            </a>
            <div class="row g-4 align-items-end mt-1">
                <div class="col-lg-9">
                    <p class="eyebrow">@school.Name</p>
                    <h1>@title</h1>
                    <p>@intro</p>
                </div>
            </div>
        </div>
    }

    @if (slug == "admissions")
    {
        <section class="admissions-enquiry-shell">
            <div class="row g-4">
                <div class="col-12 col-xl-8">
                    <div class="panel admissions-enquiry-card">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                            <div>
                                <p class="eyebrow">Admission application</p>
                                <h2 class="mb-1">Apply for admission</h2>
                                <p class="mb-0">Fill in the mandatory details below and submit the admission request to the school.</p>
                            </div>
                            <span class="badge rounded-pill text-bg-success align-self-start">Online application</span>
                        </div>

                        @if (admissionSubmitted)
                        {
                            <div class="alert alert-success admissions-success" role="status">
                                <strong>Application submitted.</strong>
                                <span>@submissionMessage</span>
                            </div>
                        }

                        <EditForm Model="admissionApplication" OnValidSubmit="SubmitAdmissionApplication">
                            <DataAnnotationsValidator />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="studentFullName">Student full name</label>
                                    <InputText id="studentFullName" class="form-control form-control-lg" @bind-Value="admissionApplication.StudentFullName" />
                                    <ValidationMessage For="() => admissionApplication.StudentFullName" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="dob">Date of birth</label>
                                    <InputDate id="dob" class="form-control form-control-lg" @bind-Value="admissionApplication.DateOfBirth" />
                                    <ValidationMessage For="() => admissionApplication.DateOfBirth" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="gender">Gender</label>
                                    <InputSelect id="gender" class="form-select form-select-lg" @bind-Value="admissionApplication.Gender">
                                        <option value="">Select gender</option>
                                        <option value="Female">Female</option>
                                        <option value="Male">Male</option>
                                        <option value="Other">Other</option>
                                    </InputSelect>
                                    <ValidationMessage For="() => admissionApplication.Gender" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="classApplying">Class applying for</label>
                                    <InputSelect id="classApplying" class="form-select form-select-lg" @bind-Value="admissionApplication.ClassApplyingFor">
                                        <option value="">Select class</option>
                                        @foreach (var className in school.StudentTimetables.Select(tt => tt.ClassName))
                                        {
                                            <option value="@className">@className</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => admissionApplication.ClassApplyingFor" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="parentName">Parent / guardian name</label>
                                    <InputText id="parentName" class="form-control form-control-lg" @bind-Value="admissionApplication.ParentName" />
                                    <ValidationMessage For="() => admissionApplication.ParentName" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="relationship">Relationship to student</label>
                                    <InputSelect id="relationship" class="form-select form-select-lg" @bind-Value="admissionApplication.Relationship">
                                        <option value="">Select relationship</option>
                                        <option value="Father">Father</option>
                                        <option value="Mother">Mother</option>
                                        <option value="Guardian">Guardian</option>
                                    </InputSelect>
                                    <ValidationMessage For="() => admissionApplication.Relationship" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="mobile">Mobile number</label>
                                    <InputText id="mobile" class="form-control form-control-lg" @bind-Value="admissionApplication.Mobile" />
                                    <ValidationMessage For="() => admissionApplication.Mobile" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="email">Email address</label>
                                    <InputText id="email" type="email" class="form-control form-control-lg" @bind-Value="admissionApplication.Email" />
                                    <ValidationMessage For="() => admissionApplication.Email" />
                                </div>

                                <div class="col-12">
                                    <label class="form-label" for="address">Residential address</label>
                                    <InputText id="address" class="form-control form-control-lg" @bind-Value="admissionApplication.Address" />
                                    <ValidationMessage For="() => admissionApplication.Address" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="previousSchool">Previous school</label>
                                    <InputText id="previousSchool" class="form-control form-control-lg" @bind-Value="admissionApplication.PreviousSchool" />
                                    <ValidationMessage For="() => admissionApplication.PreviousSchool" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" for="academicYear">Academic year</label>
                                    <InputText id="academicYear" class="form-control form-control-lg" @bind-Value="admissionApplication.AcademicYear" />
                                    <ValidationMessage For="() => admissionApplication.AcademicYear" />
                                </div>

                                <div class="col-12">
                                    <label class="form-label" for="details">Additional details</label>
                                    <InputTextArea id="details" rows="5" class="form-control form-control-lg" @bind-Value="admissionApplication.AdditionalDetails" />
                                    <ValidationMessage For="() => admissionApplication.AdditionalDetails" />
                                </div>

                                <div class="col-12 d-flex flex-wrap gap-2">
                                    <button class="btn btn-warning btn-lg fw-bold" type="submit">Submit admission</button>
                                    <button class="btn btn-outline-secondary btn-lg fw-semibold" type="button" @onclick="ResetAdmissionForm">Reset form</button>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>

                <div class="col-12 col-xl-4">
                    <div class="panel admissions-side-card h-100">
                        <p class="eyebrow">School contact</p>
                        <h2 class="mb-3">Who will contact you</h2>
                        <p class="mb-4">The admissions and office team will review the application and reach out using the details you provide.</p>

                        <div class="admissions-team-list">
                            @foreach (var contact in school.FacultyContacts)
                            {
                                <article class="admissions-team-item">
                                    <div>
                                        <h3>@contact.Name</h3>
                                        <p>@contact.Role</p>
                                    </div>
                                    <a class="contact-action" href="tel:@contact.Phone">
                                        <span class="bi bi-telephone-fill" aria-hidden="true"></span>
                                        @contact.Phone
                                    </a>
                                </article>
                            }
                        </div>

                        <div class="admissions-note">
                            <strong>School office</strong>
                            <p>@school.Email</p>
                            <a class="btn btn-outline-success w-100" href="mailto:@school.Email">Email office</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }

    @if (hasRoleMismatch || showRoleAccessPopup)
    {
        <div class="admissions-popup-backdrop" role="presentation" @onclick="CloseRoleAccessPopup">
            <div class="admissions-popup admissions-popup-small role-access-popup" role="alertdialog" aria-modal="true" aria-labelledby="role-access-title" @onclick:stopPropagation="true">
                <div class="admissions-popup-header">
                    <div>
                        <p class="eyebrow mb-1">Access denied</p>
                        <h2 id="role-access-title" class="mb-0">@GetRoleAccessTitle(portalRole)</h2>
                    </div>
                    <button type="button" class="admissions-popup-close" aria-label="Close access error" @onclick="CloseRoleAccessPopup">x</button>
                </div>
                <p class="mb-3">@GetRoleAccessMessage(portalRole)</p>
                <a class="btn btn-warning fw-bold" href="/#top">Back to home</a>
            </div>
        </div>
    }

    @if (showAlreadyLoggedInPopup)
    {
        <div class="admissions-popup-backdrop" role="presentation" @onclick="CloseAlreadyLoggedInPopup">
            <div class="admissions-popup admissions-popup-small role-access-popup" role="alertdialog" aria-modal="true" aria-labelledby="already-logged-in-title" @onclick:stopPropagation="true">
                <div class="admissions-popup-header">
                    <div>
                        <p class="eyebrow mb-1">Already logged in</p>
                        <h2 id="already-logged-in-title" class="mb-0">@GetAlreadyLoggedInTitle(portalRole)</h2>
                    </div>
                    <button type="button" class="admissions-popup-close" aria-label="Close already logged in notice" @onclick="CloseAlreadyLoggedInPopup">x</button>
                </div>
                <p class="mb-3">@GetAlreadyLoggedInMessage(portalRole)</p>
                <button class="btn btn-warning fw-bold" type="button" @onclick="CloseAlreadyLoggedInPopup">OK</button>
            </div>
        </div>
    }

    @if (showLoginRequestPopup)
    {
        <div class="admissions-popup-backdrop" role="presentation" @onclick="CloseLoginRequestPopup">
            <div class="admissions-popup admissions-popup-small role-access-popup login-request-popup" role="dialog" aria-modal="true" aria-labelledby="feature-login-request-title" @onclick:stopPropagation="true">
                <div class="admissions-popup-header">
                    <div>
                        <p class="eyebrow mb-1">@GetLoginRequestEyebrow(loginRequestRole)</p>
                        <h2 id="feature-login-request-title" class="mb-0">@GetLoginRequestTitle(loginRequestRole)</h2>
                    </div>
                    <button type="button" class="admissions-popup-close" aria-label="Close login request" @onclick="CloseLoginRequestPopup">x</button>
                </div>

                <p class="mb-3">@GetLoginRequestMessage(loginRequestRole)</p>

                <div class="mb-3">
                    <label class="form-label" for="feature-login-pin">PIN</label>
                    <div class="input-shell @(string.IsNullOrWhiteSpace(loginRequestPinError) ? string.Empty : "is-invalid")">
                        <span class="bi bi-person-badge-fill" aria-hidden="true"></span>
                        <InputText id="feature-login-pin" class="form-control form-control-lg" @bind-Value="loginRequestModel.Pin" autocomplete="username" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(loginRequestPinError))
                    {
                        <div class="field-error">@loginRequestPinError</div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label" for="feature-login-password">Password</label>
                    <div class="input-shell @(string.IsNullOrWhiteSpace(loginRequestPasswordError) ? string.Empty : "is-invalid")">
                        <span class="bi bi-shield-lock-fill" aria-hidden="true"></span>
                        <InputText id="feature-login-password" type="password" class="form-control form-control-lg" @bind-Value="loginRequestModel.Password" autocomplete="current-password" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(loginRequestPasswordError))
                    {
                        <div class="field-error">@loginRequestPasswordError</div>
                    }
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-warning btn-lg fw-bold flex-grow-1" type="button" @onclick="SubmitLoginRequest">Continue</button>
                </div>
            </div>
        </div>
    }

    @if (requiresAuthentication && !isPortalAuthenticated && !hasRoleMismatch && !showRoleAccessPopup)
    {
        <div class="auth-shell auth-shell-centered auth-login-only">
            <div class="row g-4 justify-content-center position-relative">
                <div class="col-12 col-md-10 col-lg-7 col-xl-6">
                    <div class="panel auth-preview auth-login-card">
                        <div class="auth-preview-header">
                            <div>
                                <p class="eyebrow">@school.Name</p>
                                <h2>Login required</h2>
                            </div>
                            <span class="auth-status-dot" aria-label="Secure portal active"></span>
                        </div>
                        <p>Use the Login page to choose Student or Teacher access and continue to this portal.</p>
                        <button class="btn btn-warning btn-lg w-100 fw-bold auth-submit" type="button" @onclick="() => OpenLoginRequestPopup(portalRole)">Open Login</button>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (roleModules.Count > 0)
    {
        <div class="feature-hero portal-feature-hero">
            @if (portalRole == PortalRoles.Student)
            {
                var activeSession = PortalSession.GetActiveSession();
                <div class="portal-container-actions">
                    <div class="student-profile-shell">
                        <button class="student-profile-button" type="button" @onclick="ToggleStudentProfileMenu">
                            <span class="student-profile-avatar" aria-hidden="true">
                                @GetStudentAvatar(activeSession)
                            </span>
                            <span class="student-profile-copy">
                                <strong>@(activeSession?.DisplayName ?? "Student User")</strong>
                                <span>@(string.IsNullOrWhiteSpace(activeSession?.ClassName) ? "Student class" : activeSession.ClassName)</span>
                            </span>
                            <span class="student-profile-caret bi bi-caret-down-fill" aria-hidden="true"></span>
                        </button>

                        @if (isStudentProfileMenuOpen)
                        {
                            <div class="student-profile-menu" role="menu" aria-label="Student profile options">
                                <button class="student-profile-menu-item" type="button" role="menuitem" @onclick="OpenStudentProfile">
                                    View profile
                                </button>
                                <button class="student-profile-menu-item text-danger" type="button" role="menuitem" @onclick="() => SignOut(portalRole)">
                                    Sign out
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (portalRole == PortalRoles.Teacher)
            {
                var activeSession = PortalSession.GetActiveSession();
                <div class="portal-container-actions">
                    <div class="student-profile-shell">
                        <button class="student-profile-button" type="button" @onclick="ToggleTeacherProfileMenu">
                            <span class="student-profile-avatar" aria-hidden="true">
                                @GetTeacherAvatar(activeSession)
                            </span>
                            <span class="student-profile-copy">
                                <strong>@(activeSession?.DisplayName ?? "Teacher User")</strong>
                                <span>@(string.IsNullOrWhiteSpace(activeSession?.ClassName) ? "Teacher class" : activeSession.ClassName)</span>
                            </span>
                            <span class="student-profile-caret bi bi-caret-down-fill" aria-hidden="true"></span>
                        </button>

                        @if (isTeacherProfileMenuOpen)
                        {
                            <div class="student-profile-menu" role="menu" aria-label="Teacher profile options">
                                <button class="student-profile-menu-item" type="button" role="menuitem" @onclick="OpenTeacherProfile">
                                    View profile
                                </button>
                                <button class="student-profile-menu-item text-danger" type="button" role="menuitem" @onclick="() => SignOut(portalRole)">
                                    Sign out
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
            <div class="row g-4 align-items-end mt-1">
                <div class="col-lg-9">
                    <p class="eyebrow">@school.Name</p>
                    <h1>@title</h1>
                    <p>@intro</p>
                </div>
            </div>
        </div>

        <div class="row g-3 mt-1">
            @foreach (var module in roleModules.Select((Value, Index) => new { Value, Index }))
            {
                <div class="col-12 col-lg-6 col-xxl-4">
                    <article class="panel role-card h-100">
                        <div class="d-flex align-items-start justify-content-between gap-3">
                            <div class="role-icon">@(module.Index + 1)</div>
                            <span class="badge rounded-pill text-bg-light">Module</span>
                        </div>
                        <h2>@module.Value.Title</h2>
                        <p>@module.Value.Description</p>
                        <ul class="task-list">
                            @foreach (var task in module.Value.Tasks)
                            {
                                <li>@task</li>
                            }
                        </ul>

                        @if (portalRole == PortalRoles.Student && module.Value.Title == "Timetable")
                        {
                            <button class="btn btn-outline-success w-100 mt-3" type="button" @onclick="OpenTimetablePopup">
                                Open module
                            </button>
                        }
                        else if (portalRole == PortalRoles.Student && module.Value.Title == "Curriculum")
                        {
                            <button class="btn btn-outline-success w-100 mt-3" type="button" @onclick="OpenCurriculumPopup">
                                Open module
                            </button>
                        }
                        else if (portalRole == PortalRoles.Student && module.Value.Title == "Study Content")
                        {
                            <button class="btn btn-outline-success w-100 mt-3" type="button" @onclick="OpenStudentContentPopup">
                                Open module
                            </button>
                        }
                        else if (portalRole == PortalRoles.Student && module.Value.Title == "Attendance and Progress")
                        {
                            <button class="btn btn-outline-success w-100 mt-3" type="button" @onclick="OpenStudentProgressPopup">
                                Open module
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success w-100 mt-3" type="button" disabled>View module</button>
                        }
                    </article>
                </div>
            }
        </div>

        @if (portalRole == PortalRoles.Student && isTimetablePopupOpen && school.StudentTimetables.Count > 0)
        {
            var selectedTimetable = GetSelectedTimetable(school.StudentTimetables);

            <div class="timetable-popup-backdrop" role="presentation" @onclick="CloseTimetablePopup">
                <div class="timetable-popup" role="dialog" aria-modal="true" aria-labelledby="timetable-popup-title" @onclick:stopPropagation="true">
                    <div class="timetable-popup-header">
                        <div>
                            <p class="eyebrow mb-1">Student Timetable</p>
                            <h2 id="timetable-popup-title" class="mb-0">Nursery, LKG, UKG, Class 1 to 5</h2>
                        </div>
                        <button type="button"
                                class="timetable-popup-close"
                                aria-label="Close timetable"
                                @onclick="CloseTimetablePopup">
                            x
                        </button>
                    </div>

                    @if (selectedTimetable is not null)
                    {
                        <div class="timetable-module-shell timetable-popup-body">
                            <div class="timetable-class-tabs" role="tablist" aria-label="Class timetable selector">
                                @foreach (var timetable in school.StudentTimetables)
                                {
                                    <button type="button"
                                            class="@GetTimetableTabClass(timetable.ClassName)"
                                            @onclick="() => SelectTimetable(timetable.ClassName)">
                                        @timetable.ClassName
                                    </button>
                                }
                            </div>

                            <div class="timetable-viewer">
                                <div class="timetable-viewer-header">
                                    <div>
                                        <p class="eyebrow mb-1">@selectedTimetable.ClassName</p>
                                        <h3 class="mb-0">Weekly Schedule</h3>
                                    </div>
                                    <div class="timetable-meta">
                                        <span>@selectedTimetable.PeriodLabels.Length periods</span>
                                        <span>Monday - Saturday</span>
                                    </div>
                                </div>

                                <div class="table-responsive timetable-table-wrap">
                                    <table class="table table-bordered align-middle timetable-table">
                                        <thead>
                                            <tr>
                                                <th scope="col" class="timetable-day-col">Day</th>
                                                @foreach (var period in selectedTimetable.PeriodLabels)
                                                {
                                                    <th scope="col">@period</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var day in selectedTimetable.Days)
                                            {
                                                <tr>
                                                    <th scope="row" class="timetable-day-col">@day.Day</th>
                                                    @foreach (var lesson in day.Lessons)
                                                    {
                                                        <td>@lesson</td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (portalRole == PortalRoles.Student && isCurriculumPopupOpen && school.StudentCurricula.Count > 0)
        {
            var selectedCurriculum = GetSelectedCurriculum(school.StudentCurricula);

            <div class="timetable-popup-backdrop" role="presentation" @onclick="CloseCurriculumPopup">
                <div class="timetable-popup curriculum-popup" role="dialog" aria-modal="true" aria-labelledby="curriculum-popup-title" @onclick:stopPropagation="true">
                    <div class="timetable-popup-header">
                        <div>
                            <p class="eyebrow mb-1">Student Curriculum</p>
                            <h2 id="curriculum-popup-title" class="mb-0">Nursery, LKG, UKG, Class 1 to 5</h2>
                        </div>
                        <button type="button"
                                class="timetable-popup-close"
                                aria-label="Close curriculum"
                                @onclick="CloseCurriculumPopup">
                            x
                        </button>
                    </div>

                    @if (selectedCurriculum is not null)
                    {
                        <div class="timetable-module-shell timetable-popup-body">
                            <div class="timetable-class-tabs" role="tablist" aria-label="Class curriculum selector">
                                @foreach (var curriculum in school.StudentCurricula)
                                {
                                    <button type="button"
                                            class="@GetCurriculumTabClass(curriculum.ClassName)"
                                            @onclick="() => SelectCurriculum(curriculum.ClassName)">
                                        @curriculum.ClassName
                                    </button>
                                }
                            </div>

                            <div class="curriculum-viewer">
                                <div class="timetable-viewer-header">
                                    <div>
                                        <p class="eyebrow mb-1">@selectedCurriculum.ClassName</p>
                                        <h3 class="mb-0">Academic Plan</h3>
                                    </div>
                                    <div class="timetable-meta">
                                        <span>@GetCurriculumSubjects(selectedCurriculum).Count subjects</span>
                                        <span>Weekly learning structure</span>
                                    </div>
                                </div>

                                <div class="timetable-class-tabs curriculum-subject-tabs" role="tablist" aria-label="Subject curriculum selector">
                                    @foreach (var subject in GetCurriculumSubjects(selectedCurriculum))
                                    {
                                        <button type="button"
                                                class="@GetCurriculumSubjectTabClass(subject)"
                                                @onclick="() => SelectCurriculumSubject(subject)">
                                            @subject
                                        </button>
                                    }
                                </div>

                                <div class="curriculum-unit-list">
                                    @foreach (var unit in GetFilteredCurriculumUnits(selectedCurriculum))
                                    {
                                        <article class="curriculum-unit-card">
                                            <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                                                <div>
                                                    <p class="eyebrow mb-1">@unit.Subject</p>
                                                    <h4 class="mb-2">@unit.Outcome</h4>
                                                </div>
                                                <span class="badge rounded-pill text-bg-light">Unit</span>
                                            </div>

                                            <ul class="curriculum-topic-list">
                                                @foreach (var topic in unit.Topics)
                                                {
                                                    <li>@topic</li>
