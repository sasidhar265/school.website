            <div class="timetable-popup-backdrop" role="presentation" @onclick="CloseStudentContentPopup">
                <div class="timetable-popup curriculum-popup" role="dialog" aria-modal="true" aria-labelledby="student-content-popup-title" @onclick:stopPropagation="true">
                    <div class="timetable-popup-header">
                        <div>
                            <p class="eyebrow mb-1">Student Content</p>
