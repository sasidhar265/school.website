                                            <div>
                                                <p class="eyebrow mb-1">@item.Category@(!string.IsNullOrWhiteSpace(item.Subject) ? $" · {item.Subject}" : string.Empty)</p>
                                                <h4 class="mb-2">@item.Title</h4>
                                            </div>
                                            @if (string.Equals(item.Category, "Assessments", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button class="btn btn-warning btn-sm fw-bold" type="button" @onclick="() => OpenAssessment(item)">
