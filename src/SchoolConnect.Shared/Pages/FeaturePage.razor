                </div>
            </div>
        }
    }
    else if (slug != "admissions")
    {
        <div class="row g-3 mt-1">
            <div class="col-md-6">
                <div class="panel h-100">
                    <h2>Included workflow</h2>
                    <ul class="task-list">
                        <li>Role-specific access for school staff and families.</li>
                        <li>Mobile-friendly screens shared by web, Android, and iOS.</li>
                        <li>Ready for API integration with SQL Server or PostgreSQL.</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="panel h-100">
                    <h2>Next integration</h2>
                    <p>
                        Add authentication, database entities, push notifications, and payment gateway credentials when the
                        school operations data is available.
                    </p>
                </div>
            </div>
        </div>
    }
</section>

@code {
    private const string AlreadyLoggedInNoticeKey = "schoolconnect.alreadyLoggedInNotice";
    private readonly AdmissionApplicationModel admissionApplication = new();
    private string? activeStudentModule;
    private string? activeTimetableClass;
    private string? activeCurriculumClass;
    private string? activeCurriculumSubject;
    private string? activeStudentContentClass;
    private string? activeStudentContentCategory;
    private string? activeAssessmentSubject;
    private StudentStudyContentItem? activeAssessment;
    private readonly List<AssessmentAnswerState> assessmentAnswers = [];
    private bool assessmentSubmitted;
    private string? assessmentMessage;
    private string? activeStudentProgressClass;
    private bool isTimetablePopupOpen;
    private bool isCurriculumPopupOpen;
    private bool isStudentContentPopupOpen;
    private bool isStudentProgressPopupOpen;
    private bool isStudentProfileMenuOpen;
    private bool isStudentProfilePopupOpen;
    private bool isTeacherProfileMenuOpen;
    private bool isTeacherProfilePopupOpen;
    private bool showRoleAccessPopup;
    private bool showAlreadyLoggedInPopup;
    private bool showLoginRequestPopup;
    private bool admissionSubmitted;
    private string? submissionMessage;
    private string loginRequestRole = PortalRoles.Student;
    private readonly LoginRequestModel loginRequestModel = new();
    private string? loginRequestPinError;
    private string? loginRequestPasswordError;

    private void ResetAdmissionForm()
    {
        admissionSubmitted = false;
        submissionMessage = null;
        admissionApplication.Reset();
    }

    private void SubmitAdmissionApplication()
    {
        var school = Content.GetProfile();
        admissionSubmitted = true;
        submissionMessage = $"Thanks {admissionApplication.ParentName.Trim()}. {school.Name} will review the admission request for {admissionApplication.StudentFullName} and contact you on {admissionApplication.Mobile}.";
    }

    private async Task SignOut(string role)
    {
        PortalSession.SignOut(role);

        try
        {
            await JsRuntime.InvokeVoidAsync("sessionStorage.removeItem", PortalSessionService.BrowserSessionRoleKey);
            await JsRuntime.InvokeVoidAsync("sessionStorage.removeItem", "schoolconnect.alreadyLoggedInNotice");
        }
        catch
        {
            // The authenticated server-side session is already cleared, so sign-out
            // should still return home when browser storage is unavailable.
        }

        Navigation.NavigateTo("/#top", forceLoad: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var requiredRole = GetRequiredPortalRole();
        if (!firstRender || requiredRole is null)
        {
            return;
        }

        if (PortalSession.IsAuthenticated(requiredRole))
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("sessionStorage.setItem", PortalSessionService.BrowserSessionRoleKey, PortalSession.CreateSessionToken());
            }
            catch
            {
                // Session storage is a convenience layer; the portal session itself remains authoritative.
            }

            if (await ShouldShowAlreadyLoggedInPopup(requiredRole))
            {
                showAlreadyLoggedInPopup = true;
                StateHasChanged();
            }

            return;
        }

        string? storedRole = null;
        try
        {
            storedRole = await JsRuntime.InvokeAsync<string?>("sessionStorage.getItem", PortalSessionService.BrowserSessionRoleKey);
        }
        catch
        {
            // Ignore storage access failures and fall back to the rendered login state.
        }

        if (PortalSession.RestoreAuthenticatedRole(storedRole))
        {
            var restoredSession = PortalSession.GetActiveSession();
            if (restoredSession is not null && restoredSession.Role != requiredRole)
            {
                showRoleAccessPopup = true;
            }
            else if (restoredSession is not null && await ShouldShowAlreadyLoggedInPopup(requiredRole))
            {
                showAlreadyLoggedInPopup = true;
            }

            StateHasChanged();
        }
    }

    private string? GetRequiredPortalRole()
    {
        var slug = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
        return slug switch
        {
            "student-login" => PortalRoles.Student,
            "teacher-login" => PortalRoles.Teacher,
            _ => null
        };
    }

    private void CloseRoleAccessPopup()
    {
        showRoleAccessPopup = false;
        Navigation.NavigateTo("/#top");
    }

    private void CloseAlreadyLoggedInPopup()
    {
        showAlreadyLoggedInPopup = false;
        Navigation.NavigateTo($"/{Navigation.ToBaseRelativePath(Navigation.Uri).Split('?')[0]}", forceLoad: false);
    }

    private void OpenLoginRequestPopup(string role)
    {
        loginRequestRole = role;
        loginRequestModel.Pin = null;
        loginRequestModel.Password = null;
        loginRequestPinError = null;
        loginRequestPasswordError = null;
        showLoginRequestPopup = true;
    }

    private void CloseLoginRequestPopup()
    {
        showLoginRequestPopup = false;
        loginRequestPinError = null;
        loginRequestPasswordError = null;
    }

    private async Task SubmitLoginRequest()
    {
        loginRequestPinError = null;
        loginRequestPasswordError = null;

        if (string.IsNullOrWhiteSpace(loginRequestModel.Pin))
        {
            loginRequestPinError = "PIN is required.";
        }

        if (string.IsNullOrWhiteSpace(loginRequestModel.Password))
        {
            loginRequestPasswordError = "Password is required.";
        }

        if (!string.IsNullOrWhiteSpace(loginRequestPinError) || !string.IsNullOrWhiteSpace(loginRequestPasswordError))
        {
            return;
        }

        if (!PortalSession.TrySignIn(loginRequestRole, loginRequestModel.Pin, loginRequestModel.Password))
        {
            loginRequestPinError = "PIN or password does not match the selected login type.";
            loginRequestPasswordError = "Check your password and try again.";
            return;
        }

        try
        {
            await JsRuntime.InvokeVoidAsync("sessionStorage.setItem", PortalSessionService.BrowserSessionRoleKey, PortalSession.CreateSessionToken());
        }
        catch
        {
            // The in-memory session remains authoritative if browser storage is unavailable.
        }

        showLoginRequestPopup = false;
        Navigation.NavigateTo(loginRequestRole == PortalRoles.Teacher ? "/teacher-login" : "/student-login");
    }

    private bool HasAlreadyLoggedInFlag()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        return uri.Query.Contains("alreadyLoggedIn=true", StringComparison.OrdinalIgnoreCase);
    }

    private async Task<bool> ShouldShowAlreadyLoggedInPopup(string requiredRole)
    {
        if (HasAlreadyLoggedInFlag())
        {
            return true;
        }

        string? noticeRole = null;
        try
        {
            noticeRole = await JsRuntime.InvokeAsync<string?>("sessionStorage.getItem", AlreadyLoggedInNoticeKey);
            await JsRuntime.InvokeVoidAsync("sessionStorage.removeItem", AlreadyLoggedInNoticeKey);
        }
        catch
        {
            return false;
        }

        return string.Equals(noticeRole, requiredRole, StringComparison.OrdinalIgnoreCase);
    }

    private static string GetAlreadyLoggedInTitle(string role)
    {
        return role == PortalRoles.Teacher
            ? "Teacher portal is already active"
            : "Student portal is already active";
    }

    private static string GetAlreadyLoggedInMessage(string role)
    {
        return role == PortalRoles.Teacher
            ? "Teacher user is already logged in. Redirecting to the teacher portal instead of the login page."
            : "Student user is already logged in. Redirecting to the student portal instead of the login page.";
    }

    private static string GetLoginRequestEyebrow(string role)
    {
        return role == PortalRoles.Teacher ? "Teacher login request" : "Student login request";
    }

    private static string GetLoginRequestTitle(string role)
    {
        return role == PortalRoles.Teacher ? "Teacher portal access" : "Student portal access";
    }

    private static string GetLoginRequestMessage(string role)
    {
        return role == PortalRoles.Teacher
            ? "Enter the teacher PIN and password to continue in the teacher portal."
            : "Enter the student PIN and password to continue in the student portal.";
    }

    private static string GetRoleAccessTitle(string requiredRole)
    {
        return requiredRole == PortalRoles.Teacher
            ? "Teacher portal unavailable"
            : "Student portal unavailable";
    }

    private static string GetRoleAccessMessage(string requiredRole)
    {
        return requiredRole == PortalRoles.Teacher
            ? "Student users can't log in to the teacher portal. Please log out from the student portal before using teacher login."
            : "Teacher users can't log in to the student portal. Please log out from the teacher portal before using student login.";
    }

    private sealed class LoginRequestModel
    {
        [Required(ErrorMessage = "PIN is required.")]
        public string? Pin { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        public string? Password { get; set; }
    }

    private void ToggleStudentModule(string moduleTitle)
    {
        activeStudentModule = activeStudentModule == moduleTitle ? null : moduleTitle;
        if (activeStudentModule != "Timetable")
        {
            activeTimetableClass = null;
            isTimetablePopupOpen = false;
        }

        if (activeStudentModule != "Curriculum")
        {
            activeCurriculumClass = null;
            isCurriculumPopupOpen = false;
        }

        if (activeStudentModule != "Study Content")
        {
            activeStudentContentClass = null;
            activeStudentContentCategory = null;
            isStudentContentPopupOpen = false;
        }

        if (activeStudentModule != "Attendance and Progress")
        {
            activeStudentProgressClass = null;
            isStudentProgressPopupOpen = false;
        }

        if (activeStudentModule != "Student Profile")
        {
            isStudentProfileMenuOpen = false;
            isStudentProfilePopupOpen = false;
        }

        if (activeStudentModule != "Teacher Profile")
        {
            isTeacherProfileMenuOpen = false;
            isTeacherProfilePopupOpen = false;
        }
    }

    private void OpenTimetablePopup()
    {
        activeStudentModule = "Timetable";
        isTimetablePopupOpen = true;
    }

    private void OpenCurriculumPopup()
    {
        activeStudentModule = "Curriculum";
        isCurriculumPopupOpen = true;
    }

    private void OpenStudentContentPopup()
    {
        activeStudentModule = "Study Content";
        isStudentContentPopupOpen = true;
    }

