    private string GetStudentAvatar(PortalSessionInfo? session)
    {
        var name = session?.DisplayName?.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            return "S";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 1)
        {
            return parts[0].Length > 0 ? parts[0][0].ToString().ToUpperInvariant() : "S";
        }

        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private string GetTeacherAvatar(PortalSessionInfo? session) => GetStudentAvatar(session);

    private sealed class AdmissionApplicationModel
    {
        [Required(ErrorMessage = "Student full name is required.")]
        public string StudentFullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Date of birth is required.")]
        public DateTime? DateOfBirth { get; set; }

        [Required(ErrorMessage = "Please select the gender.")]
        public string Gender { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please select the class.")]
        public string ClassApplyingFor { get; set; } = string.Empty;

        [Required(ErrorMessage = "Parent or guardian name is required.")]
        public string ParentName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Relationship to student is required.")]
        public string Relationship { get; set; } = string.Empty;

        [Required(ErrorMessage = "Mobile number is required.")]
        [Phone(ErrorMessage = "Enter a valid mobile number.")]
        public string Mobile { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email address is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Residential address is required.")]
        public string Address { get; set; } = string.Empty;

        [Required(ErrorMessage = "Previous school is required.")]
        public string PreviousSchool { get; set; } = string.Empty;

        [Required(ErrorMessage = "Academic year is required.")]
        public string AcademicYear { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please add additional details.")]
        [StringLength(500, ErrorMessage = "Additional details should stay within 500 characters.")]
        public string AdditionalDetails { get; set; } = string.Empty;

        public void Reset()
        {
            StudentFullName = string.Empty;
            DateOfBirth = null;
            Gender = string.Empty;
            ClassApplyingFor = string.Empty;
            ParentName = string.Empty;
            Relationship = string.Empty;
            Mobile = string.Empty;
            Email = string.Empty;
            Address = string.Empty;
            PreviousSchool = string.Empty;
            AcademicYear = string.Empty;
            AdditionalDetails = string.Empty;
        }
    }

    private sealed class AssessmentAnswerState(int questionNumber)
    {
        public int QuestionNumber { get; } = questionNumber;

        public string Response { get; set; } = string.Empty;
    }

