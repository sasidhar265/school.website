                                    <article class="curriculum-unit-card">
                                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                                            <div>
                                                <p class="eyebrow mb-1">@subject.Subject</p>
                                                <h4 class="mb-2">@subject.Score</h4>
                                            </div>
                                            <span class="badge rounded-pill text-bg-light">Subject progress</span>
                                        </div>
                                        <p class="mb-0 text-muted">@subject.Remark</p>
                                    </article>
                                }
