                        </div>
                        <button type="button" class="timetable-popup-close" aria-label="Close student content" @onclick="CloseStudentContentPopup">x</button>
                    </div>

                    @if (selectedContent is not null)
                    {
                        <div class="timetable-module-shell timetable-popup-body">
                            <div class="timetable-class-tabs" role="tablist" aria-label="Class content selector">
                                @foreach (var content in school.StudentContents)
                                {
                                    <button type="button"
                                            class="@GetStudentContentTabClass(content.ClassName)"
                                            @onclick="() => SelectStudentContent(content.ClassName)">
                                        @content.ClassName
                                    </button>
                                }
                            </div>

                            <div class="timetable-class-tabs curriculum-subject-tabs" role="tablist" aria-label="Content category selector">
                                @foreach (var category in GetStudentContentCategories(selectedContent))
                                {
                                    <button type="button"
                                            class="@GetStudentContentCategoryTabClass(category)"
                                            @onclick="() => SelectStudentContentCategory(category)">
                                        @category
                                    </button>
                                }
                            </div>

                            @if (IsAssessmentCategorySelected())
                            {
                                <div class="timetable-class-tabs curriculum-subject-tabs" role="tablist" aria-label="Assessment subject selector">
                                    @foreach (var subject in GetAssessmentSubjects(selectedContent))
                                    {
                                        <button type="button"
                                                class="@GetAssessmentSubjectTabClass(subject)"
                                                @onclick="() => SelectAssessmentSubject(subject)">
                                            @subject
                                        </button>
                                    }
                                </div>
