                                @GetStudentAvatar(activeSession)
                            </div>
                            <div>
                                <p class="eyebrow mb-1">Logged in student</p>
                                <h3 class="mb-1">@(activeSession?.DisplayName ?? "Student User")</h3>
                                <p class="mb-0">@((activeSession?.ClassName is { Length: > 0 } className) ? className : "Class not assigned")</p>
                            </div>
                        </div>

                        <div class="curriculum-unit-list">
                            <article class="curriculum-unit-card">
                                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                                    <div>
                                        <p class="eyebrow mb-1">Profile overview</p>
                                        <h4 class="mb-2">Student details</h4>
                                    </div>
                                    <span class="badge rounded-pill text-bg-success">Active</span>
                                </div>
                                <div class="student-profile-detail-grid">
                                    <div><span>Student name</span><strong>@(activeSession?.DisplayName ?? "Student User")</strong></div>
                                    <div><span>Class</span><strong>@(activeSession?.ClassName ?? "Class not assigned")</strong></div>
                                    <div><span>Gender</span><strong>@(activeSession?.Gender ?? "Not assigned")</strong></div>
                                    <div><span>Parents / Guardian name</span><strong>@(activeSession?.GuardianName ?? "Not assigned")</strong></div>
                                    <div><span>Mobile phone number</span><strong>@(activeSession?.MobileNumber ?? "Not assigned")</strong></div>
                                    <div><span>Class teacher</span><strong>@(activeSession?.ClassTeacher ?? "Not assigned")</strong></div>
                                    <div><span>School joined year</span><strong>@(activeSession?.SchoolJoinedYear ?? "Not assigned")</strong></div>
                                </div>
                            </article>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (portalRole == PortalRoles.Teacher && isTeacherProfilePopupOpen)
        {
            var activeSession = PortalSession.GetActiveSession();
            <div class="timetable-popup-backdrop" role="presentation" @onclick="CloseTeacherProfile">
                <div class="timetable-popup curriculum-popup student-profile-popup" role="dialog" aria-modal="true" aria-labelledby="teacher-profile-popup-title" @onclick:stopPropagation="true">
                    <div class="timetable-popup-header">
                        <div>
                            <p class="eyebrow mb-1">Teacher Profile</p>
                            <h2 id="teacher-profile-popup-title" class="mb-0">Profile details</h2>
                        </div>
                        <button type="button" class="timetable-popup-close" aria-label="Close profile" @onclick="CloseTeacherProfile">x</button>
                    </div>

                    <div class="student-profile-popup-body">
                        <div class="student-profile-summary">
                            <div class="student-profile-avatar student-profile-avatar-lg" aria-hidden="true">
                                @GetTeacherAvatar(activeSession)
                            </div>
                            <div>
                                <p class="eyebrow mb-1">Logged in teacher</p>
                                <h3 class="mb-1">@(activeSession?.DisplayName ?? "Teacher User")</h3>
                                <p class="mb-0">
                                    @((activeSession?.ClassDealingWith is { Length: > 0 } className) ? className : "Class dealing not assigned")
                                </p>
                            </div>
                        </div>

                        <div class="curriculum-unit-list">
                            <article class="curriculum-unit-card">
                                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                                    <div>
                                        <p class="eyebrow mb-1">Profile overview</p>
                                        <h4 class="mb-2">Teacher details</h4>
                                    </div>
                                    <span class="badge rounded-pill text-bg-success">Active</span>
                                </div>
                                <div class="student-profile-detail-grid">
                                    <div><span>Teacher name</span><strong>@(activeSession?.DisplayName ?? "Teacher User")</strong></div>
                                    <div><span>Class dealing with</span><strong>@(activeSession?.ClassDealingWith ?? "Not assigned")</strong></div>
                                    <div><span>Subject</span><strong>@(activeSession?.Subject ?? "Not assigned")</strong></div>
                                    <div><span>Qualification</span><strong>@(activeSession?.Qualification ?? "Not assigned")</strong></div>
                                    <div><span>Gender</span><strong>@(activeSession?.Gender ?? "Not assigned")</strong></div>
