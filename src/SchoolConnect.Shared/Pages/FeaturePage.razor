            </div>
        }

        @if (portalRole == PortalRoles.Student && isStudentProfilePopupOpen)
        {
            var activeSession = PortalSession.GetActiveSession();
            <div class="timetable-popup-backdrop" role="presentation" @onclick="CloseStudentProfile">
                <div class="timetable-popup curriculum-popup student-profile-popup" role="dialog" aria-modal="true" aria-labelledby="student-profile-popup-title" @onclick:stopPropagation="true">
                    <div class="timetable-popup-header">
                        <div>
                            <p class="eyebrow mb-1">Student Profile</p>
                            <h2 id="student-profile-popup-title" class="mb-0">Profile details</h2>
                        </div>
                        <button type="button" class="timetable-popup-close" aria-label="Close profile" @onclick="CloseStudentProfile">x</button>
                    </div>

                    <div class="student-profile-popup-body">
