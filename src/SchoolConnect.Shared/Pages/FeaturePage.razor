    private void OpenAssessment(StudentStudyContentItem assessment)
    {
        activeAssessment = assessment;
        assessmentAnswers.Clear();
        foreach (var question in assessment.AssessmentQuestions)
        {
            assessmentAnswers.Add(new AssessmentAnswerState(question.Number));
        }
        assessmentSubmitted = false;
        assessmentMessage = null;
    }

    private void CloseAssessment()
    {
        activeAssessment = null;
        assessmentAnswers.Clear();
        assessmentSubmitted = false;
        assessmentMessage = null;
    }

    private string GetAssessmentResponse(int questionNumber) =>
        assessmentAnswers.FirstOrDefault(answer => answer.QuestionNumber == questionNumber)?.Response ?? string.Empty;

    private AssessmentAnswerState GetAssessmentAnswer(int questionNumber) =>
        assessmentAnswers.First(answer => answer.QuestionNumber == questionNumber);

    private async Task SubmitAssessment()
    {
        if (activeAssessment is null)
        {
            return;
        }

        var selectionPayload = await JsRuntime.InvokeAsync<string>("schoolConnectAssessment.getSelections");
        foreach (var selection in selectionPayload.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = selection.Split('\t', 2);
            if (parts.Length < 2 || !int.TryParse(parts[0], out var questionNumber))
            {
                continue;
            }

            var answer = assessmentAnswers.FirstOrDefault(item => item.QuestionNumber == questionNumber);
            if (answer is not null)
            {
                answer.Response = parts[1];
            }
        }

        var unanswered = activeAssessment.AssessmentQuestions
            .Count(question => string.IsNullOrWhiteSpace(GetAssessmentResponse(question.Number)));
        if (unanswered > 0)
        {
            assessmentMessage = $"Please answer all questions. {unanswered} {(unanswered == 1 ? "answer is" : "answers are")} still missing.";
            return;
        }

        assessmentSubmitted = true;
        var score = activeAssessment.AssessmentQuestions
            .Where(IsAssessmentAnswerCorrect)
            .Sum(question => question.Marks);
        var totalMarks = activeAssessment.AssessmentQuestions.Sum(question => question.Marks);
        assessmentMessage = $"Assessment submitted successfully. Your score is {score} out of {totalMarks}.";
    }

    private bool IsAssessmentAnswerCorrect(StudentAssessmentQuestion question) =>
        string.Equals(GetAssessmentResponse(question.Number), question.CorrectAnswer, StringComparison.Ordinal);

