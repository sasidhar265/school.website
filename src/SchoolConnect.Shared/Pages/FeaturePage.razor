    private StudentCurriculum? GetSelectedCurriculum(IReadOnlyList<StudentCurriculum> curricula)
    {
        if (curricula.Count == 0)
        {
            return null;
        }

        if (string.IsNullOrWhiteSpace(activeCurriculumClass))
        {
            activeCurriculumClass = curricula[0].ClassName;
        }

        var selectedCurriculum = curricula.FirstOrDefault(c => c.ClassName == activeCurriculumClass) ?? curricula[0];
        if (string.IsNullOrWhiteSpace(activeCurriculumSubject))
        {
            activeCurriculumSubject = GetCurriculumSubjects(selectedCurriculum).FirstOrDefault();
        }

        return selectedCurriculum;
    }

    private string GetCurriculumTabClass(string className) =>
        $"timetable-tab {(activeCurriculumClass == className ? "active" : string.Empty)}".Trim();

    private void SelectCurriculumSubject(string subject)
    {
        activeCurriculumSubject = subject;
    }

    private IReadOnlyList<string> GetCurriculumSubjects(StudentCurriculum curriculum) =>
        curriculum.Subjects.Length > 0
            ? curriculum.Subjects.Distinct(StringComparer.OrdinalIgnoreCase).ToArray()
            : curriculum.Units.Select(unit => unit.Subject).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();

    private IReadOnlyList<StudentCurriculumUnit> GetFilteredCurriculumUnits(StudentCurriculum curriculum)
    {
        var subjects = GetCurriculumSubjects(curriculum);
        if (subjects.Count == 0)
        {
            return curriculum.Units;
        }

        if (string.IsNullOrWhiteSpace(activeCurriculumSubject) || !subjects.Contains(activeCurriculumSubject, StringComparer.OrdinalIgnoreCase))
        {
            activeCurriculumSubject = subjects[0];
        }

        return curriculum.Units
            .Where(unit => string.Equals(unit.Subject, activeCurriculumSubject, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

    private string GetCurriculumSubjectTabClass(string subject) =>
        ("timetable-tab " + (string.Equals(activeCurriculumSubject, subject, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)).Trim();

    private StudentStudyContent? GetSelectedStudentContent(IReadOnlyList<StudentStudyContent> contents)
    {
        if (contents.Count == 0)
        {
            return null;
        }

        if (string.IsNullOrWhiteSpace(activeStudentContentClass))
        {
            activeStudentContentClass = contents[0].ClassName;
        }

        var selectedContent = contents.FirstOrDefault(content => content.ClassName == activeStudentContentClass) ?? contents[0];
        if (string.IsNullOrWhiteSpace(activeStudentContentCategory))
        {
            activeStudentContentCategory = GetStudentContentCategories(selectedContent).FirstOrDefault();
        }

        return selectedContent;
    }

    private IReadOnlyList<string> GetStudentContentCategories(StudentStudyContent content) =>
        content.Categories.Length > 0
            ? content.Categories.Distinct(StringComparer.OrdinalIgnoreCase).ToArray()
            : content.Items.Select(item => item.Category).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();

    private IReadOnlyList<StudentStudyContentItem> GetFilteredStudentContentItems(StudentStudyContent content)
    {
        var categories = GetStudentContentCategories(content);
        if (categories.Count == 0)
        {
            return content.Items;
        }

        if (string.IsNullOrWhiteSpace(activeStudentContentCategory) || !categories.Contains(activeStudentContentCategory, StringComparer.OrdinalIgnoreCase))
        {
            activeStudentContentCategory = categories[0];
        }

        var filtered = content.Items
            .Where(item => string.Equals(item.Category, activeStudentContentCategory, StringComparison.OrdinalIgnoreCase));

        if (IsAssessmentCategorySelected())
        {
            var subjects = GetAssessmentSubjects(content);
            if (subjects.Count > 0 && (string.IsNullOrWhiteSpace(activeAssessmentSubject) || !subjects.Contains(activeAssessmentSubject, StringComparer.OrdinalIgnoreCase)))
            {
                activeAssessmentSubject = subjects[0];
            }

            filtered = filtered.Where(item => string.Equals(item.Subject, activeAssessmentSubject, StringComparison.OrdinalIgnoreCase));
        }

        return filtered.ToArray();
    }

    private bool IsAssessmentCategorySelected() =>
        string.Equals(activeStudentContentCategory, "Assessments", StringComparison.OrdinalIgnoreCase);

    private IReadOnlyList<string> GetAssessmentSubjects(StudentStudyContent content) =>
        content.Items
            .Where(item => string.Equals(item.Category, "Assessments", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(item.Subject))
            .Select(item => item.Subject)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

