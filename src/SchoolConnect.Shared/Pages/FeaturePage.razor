    private StudentTimetable? GetSelectedTimetable(IReadOnlyList<StudentTimetable> timetables)
    {
        if (timetables.Count == 0)
        {
            return null;
        }

        if (string.IsNullOrWhiteSpace(activeTimetableClass))
        {
            activeTimetableClass = timetables[0].ClassName;
        }

        return timetables.FirstOrDefault(t => t.ClassName == activeTimetableClass) ?? timetables[0];
    }

    private string GetTimetableTabClass(string className) =>
