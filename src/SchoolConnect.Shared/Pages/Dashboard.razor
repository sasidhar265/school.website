@page "/"
@implements IDisposable
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject SchoolContentService Content
@inject PortalSessionService PortalSession
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

@{
    var school = Content.GetProfile();
}

<PageTitle>@school.Name</PageTitle>

<section id="top" class="modern-home" data-scrollspy-target="top">
    <header class="modern-topbar">
        <div class="brand-block">
            <img class="brand-mark brand-logo" src="_content/SchoolConnect.Shared/venkateswara-logo.svg" alt="Sri Venkateswara Swamy logo" />
            <div>
                <strong>@school.Name</strong>
                <small>@school.Location</small>
                <p>
                    A connected school experience for students, teachers, parents, and administrators with academics,
                    attendance, notices, transport, and management workflows.
                </p>
                <div class="hero-badges">
                    <span>@school.BoardLabel</span>
                    <span>@string.Join(", ", school.Languages)</span>
                    <span>@school.CampusLabel</span>
                </div>
            </div>
        </div>
        <div class="home-topbar-right">
            <div class="heritage-emblem" aria-label="Teaching excellence since 1986">
                <span>Since 1986</span>
                <strong>40 Years</strong>
                <small>Excellence in Teaching</small>
                <em>35+ years of trusted education</em>
            </div>
        </div>
    </header>

    <section class="hero-media-stack">
        <div id="homeCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="5000">
            <div class="carousel-indicators hero-carousel-indicators">
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Campus view"></button>
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="1" aria-label="Classroom view"></button>
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="2" aria-label="Sports view"></button>
            </div>

            <div class="carousel-inner hero-carousel-inner">
                <div class="carousel-item active">
                    <img src="_content/SchoolConnect.Shared/home-campus.jpg" class="d-block w-100 hero-carousel-image" alt="Sri Venkateswara Convent campus" />
                    <div class="carousel-caption hero-carousel-caption">
                        <span>Campus</span>
                        <h3>Bright spaces for learning</h3>
                        <p>Modern classrooms and a clean campus create a better daily school experience.</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="_content/SchoolConnect.Shared/home-classroom.jpg" class="d-block w-100 hero-carousel-image" alt="Classroom learning session" />
                    <div class="carousel-caption hero-carousel-caption">
                        <span>Classroom</span>
                        <h3>Interactive teaching moments</h3>
                        <p>Students learn in structured sessions with attentive classroom engagement.</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="_content/SchoolConnect.Shared/home-sports.jpg" class="d-block w-100 hero-carousel-image" alt="School sports and activity practice" />
                    <div class="carousel-caption hero-carousel-caption">
                        <span>Activity</span>
                        <h3>Sports and activity time</h3>
                        <p>Balanced growth comes from academics, movement, and student activities.</p>
                    </div>
                </div>
            </div>

            <button class="carousel-control-prev hero-carousel-control" type="button" data-bs-target="#homeCarousel" data-bs-slide="prev" aria-label="Previous slide">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next hero-carousel-control" type="button" data-bs-target="#homeCarousel" data-bs-slide="next" aria-label="Next slide">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
            </button>
        </div>
    </section>

    <section class="content-showcase">
        <div id="why-choose-us" class="showcase-main" data-scrollspy-target="why-choose-us">
            <div class="section-heading-modern">
                <p class="eyebrow">Why Choose Us</p>
                <h2>Designed for a complete digital school experience</h2>
            </div>
            <div class="capability-grid">
                <article>
                    <span>Academics</span>
                    <h3>Curriculum-first planning</h3>
                    <p>Class-wise timetable, syllabus, lesson units, worksheets, and exam preparation content.</p>
                </article>
                <article>
                    <span>Communication</span>
                    <h3>Notices and feedback</h3>
                    <p>Important circulars, teacher remarks, academic updates, and parent-visible progress.</p>
                </article>
                <article>
                    <span>Operations</span>
                    <h3>School management tools</h3>
                    <p>Teacher workflows for attendance, reports, events, transport coordination, and maintenance.</p>
                </article>
                <article>
                    <span>Growth</span>
                    <h3>Student progress view</h3>
                    <p>Attendance percentage, assessment summaries, homework status, and academic remarks.</p>
                </article>
            </div>
        </div>

        <aside id="latest-updates" class="notice-panel" data-scrollspy-target="latest-updates">
            <div class="section-heading-modern compact">
                <p class="eyebrow">Live Updates</p>
                <h2>News & Announcements</h2>
            </div>
            @foreach (var notice in school.Notices)
            {
                <article class="notice-item">
                    <time>@notice.Date</time>
                    <div>
                        <span>@notice.Priority</span>
                        <h3>@notice.Title</h3>
                        <p>@notice.Summary</p>
                    </div>
                </article>
            }
            <a class="btn btn-outline-success w-100 mt-3" href="/notices">View All Notices</a>
        </aside>
    </section>

    <section id="admissions" class="modern-cta admissions-inline-cta" data-scrollspy-target="admissions">
        <div class="admissions-cta-copy">
            <p class="eyebrow">@school.Name</p>
            <h2>@school.AdmissionsHeadline</h2>
        </div>
        <div class="admissions-cta-action">
            <button class="btn btn-outline-success btn-lg fw-bold admissions-action-button" type="button" @onclick="OpenAdmissionPopup">Start Enquiry</button>
            <a class="btn btn-warning btn-lg fw-bold admissions-action-button" href="/admissions">Admission Form</a>
        </div>
    </section>

    @if (showAdmissionPopup)
    {
        <div class="admissions-popup-backdrop" role="presentation" @onclick="CloseAdmissionPopup">
            <div class="admissions-popup admissions-popup-small" role="dialog" aria-modal="true" aria-labelledby="admissions-popup-title" @onclick:stopPropagation="true">
                <div class="admissions-popup-header">
                    <div>
                        <p class="eyebrow mb-1">Admission enquiry</p>
                        <h2 id="admissions-popup-title" class="mb-0">Quick enquiry</h2>
                    </div>
                    <button type="button" class="admissions-popup-close" aria-label="Close admission enquiry" @onclick="CloseAdmissionPopup">x</button>
                </div>

                @if (admissionPopupSubmitted)
                {
                    <div class="alert alert-success admissions-popup-success" role="status">
                        <strong>Enquiry submitted.</strong>
                        <span>@admissionPopupMessage</span>
                    </div>
                }

                <EditForm Model="admissionPopup" OnValidSubmit="SubmitAdmissionPopup">
                    <DataAnnotationsValidator />

                    <div class="row g-3 admissions-popup-form">
                        <div class="col-12">
                            <label class="form-label" for="popupStudent">Student name</label>
                            <InputText id="popupStudent" class="form-control" @bind-Value="admissionPopup.StudentName" />
                            <ValidationMessage For="() => admissionPopup.StudentName" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="popupParent">Parent / guardian</label>
                            <InputText id="popupParent" class="form-control" @bind-Value="admissionPopup.ParentName" />
                            <ValidationMessage For="() => admissionPopup.ParentName" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="popupClass">Class</label>
                            <InputSelect id="popupClass" class="form-select" @bind-Value="admissionPopup.ClassSeekingAdmission">
                                <option value="">Select class</option>
                                @foreach (var className in school.StudentTimetables.Select(tt => tt.ClassName))
                                {
                                    <option value="@className">@className</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => admissionPopup.ClassSeekingAdmission" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="popupMobile">Mobile number</label>
                            <InputText id="popupMobile" class="form-control" @bind-Value="admissionPopup.Mobile" />
                            <ValidationMessage For="() => admissionPopup.Mobile" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="popupEmail">Email address</label>
                            <InputText id="popupEmail" type="email" class="form-control" @bind-Value="admissionPopup.Email" />
                            <ValidationMessage For="() => admissionPopup.Email" />
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="popupDetails">Enquiry details</label>
                            <InputTextArea id="popupDetails" rows="3" class="form-control" @bind-Value="admissionPopup.Details" />
                            <ValidationMessage For="() => admissionPopup.Details" />
                        </div>

                        <div class="col-12 d-flex flex-wrap gap-2">
                            <button class="btn btn-warning fw-bold" type="submit">Submit enquiry</button>
                            <button class="btn btn-outline-secondary fw-semibold" type="button" @onclick="CloseAdmissionPopup">Close</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <section id="about-us" class="about-preview" data-scrollspy-target="about-us">
        <div class="section-heading-modern">
            <p class="eyebrow">About Us</p>
            <h2>@school.AboutUs.Title</h2>
        </div>
        <div class="about-preview-grid">
            <p>@school.AboutUs.Summary</p>
            <button class="btn btn-outline-success fw-semibold align-self-start" type="button" @onclick="OpenAboutPopup">Read About Us</button>
        </div>
    </section>

    @if (showAboutPopup)
    {
        <div class="admissions-popup-backdrop" role="presentation" @onclick="CloseAboutPopup">
            <div class="admissions-popup about-popup" role="dialog" aria-modal="true" aria-labelledby="about-popup-title" @onclick:stopPropagation="true">
                <div class="admissions-popup-header">
                    <div>
                        <p class="eyebrow mb-1">@school.Name</p>
                        <h2 id="about-popup-title" class="mb-0">Welcome to Our School</h2>
                    </div>
                    <button type="button" class="admissions-popup-close" aria-label="Close about us" @onclick="CloseAboutPopup">x</button>
                </div>

                <div class="about-popup-content">
                    <section>
                        <h3>About Us</h3>
                        <p>With a proud legacy of <strong>35+ years of excellence in education</strong>, our school has been committed to shaping young minds through quality learning, strong values, and holistic development. Since our establishment, we have provided a nurturing and inspiring environment where every child is encouraged to learn, grow, and achieve their full potential.</p>
                        <p>We offer education from <strong>Nursery to Class 5</strong> in both <strong>Telugu Medium</strong> and <strong>English Medium</strong>, ensuring that students receive a strong academic foundation while preserving cultural values and language proficiency.</p>
                        <p>Over the past three and a half decades, <strong>more than 1,000 students</strong> have successfully completed their primary education at our school. Our alumni have gone on to build successful careers across diverse fields and industries, making meaningful contributions in India and around the world. Their achievements stand as a testament to the quality of education and values instilled during their formative years.</p>
                    </section>

                    <section>
                        <h3>Our Mission</h3>
                        <p>Our mission is to provide a safe, inclusive, and stimulating learning environment that fosters academic excellence, creativity, discipline, and character. We strive to nurture confident, responsible, and compassionate individuals who are prepared to meet the challenges of the future.</p>
                    </section>

                    <section>
                        <h3>Our Vision</h3>
                        <p>To be a center of excellence in primary education by inspiring lifelong learning, promoting moral values, and empowering every child with the knowledge and skills needed to succeed in an ever-changing world.</p>
                    </section>

                    <section>
                        <h3>Why Choose Our School?</h3>
                        <ul class="task-list">
                            @foreach (var highlight in school.AboutUs.Highlights)
                            {
                                <li>@highlight</li>
                            }
                        </ul>
                    </section>

                    <section>
                        <h3>Our Commitment</h3>
                        <p>At our school, every child is valued and encouraged to discover their unique talents. We believe that education extends beyond textbooks, helping students develop confidence, curiosity, leadership, and integrity. Together with parents and the community, we are committed to building a brighter future for every learner.</p>
                    </section>
                </div>
            </div>
        </div>
    }

    @if (showRoleAccessPopup)
    {
        <div class="admissions-popup-backdrop" role="presentation" @onclick="CloseRoleAccessPopup">
            <div class="admissions-popup admissions-popup-small role-access-popup" role="alertdialog" aria-modal="true" aria-labelledby="role-access-title" @onclick:stopPropagation="true">
                <div class="admissions-popup-header">
                    <div>
                        <p class="eyebrow mb-1">Access denied</p>
                        <h2 id="role-access-title" class="mb-0">Teacher portal unavailable</h2>
                    </div>
                    <button type="button" class="admissions-popup-close" aria-label="Close access error" @onclick="CloseRoleAccessPopup">x</button>
                </div>
                <p class="mb-3">@roleAccessMessage</p>
                <button class="btn btn-warning fw-bold" type="button" @onclick="CloseRoleAccessPopup">OK</button>
            </div>
        </div>
    }

    <section class="campus-map-section" aria-label="Campus location">
            <div class="map-info">
                <p class="eyebrow">Find Campus</p>
                <h2>@school.CampusMapTitle</h2>
                <p>@school.Location</p>
                <div class="map-meta">
                    <span>@school.BoardLabel</span>
                    <span>@school.StateLabel</span>
                    <span>@school.CampusLabel</span>
                </div>
            </div>

        <div class="map-card">
            <iframe
                title="@school.CampusMapTitle"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.openstreetmap.org/export/embed.html?bbox=80.0950%2C16.4850%2C80.1850%2C16.5650&layer=mapnik&marker=16.5250%2C80.1400">
            </iframe>
        </div>
    </section>

    <section id="contacts" class="contacts-section" data-scrollspy-target="contacts">
        <div class="section-heading-modern">
            <p class="eyebrow">Contact Us</p>
            <h2>Reach the school team</h2>
        </div>

        <div class="contacts-grid">
            <article class="panel contacts-card">
                <div class="contact-row">
                    <div>
                        <p class="eyebrow">School Email</p>
                        <h3>General Office</h3>
                        <p>@school.Email</p>
                    </div>
                    <a class="contact-action" href="mailto:@school.Email">
                        <span class="bi bi-envelope-fill" aria-hidden="true"></span>
                        Email
                    </a>
                </div>
                <div class="contact-row">
                    <div>
                        <p class="eyebrow">Phone</p>
                        <h3>@school.Phone</h3>
                        <p>Call during school hours for admissions, transport, and office support.</p>
                    </div>
                    <a class="contact-action" href="tel:@school.Phone">
                        <span class="bi bi-telephone-fill" aria-hidden="true"></span>
                        Call
                    </a>
                </div>
            </article>

            <article class="panel contacts-card">
                <div class="contact-row">
                    <div>
                        <p class="eyebrow">Faculty Contacts</p>
                        <h3>Administration & Support</h3>
                        <p>Direct contacts for school coordination and academic support.</p>
                    </div>
                </div>
                @foreach (var contact in school.FacultyContacts)
                {
                    <div class="contact-row">
                        <div>
                            <h3>@contact.Name</h3>
                            <p>@contact.Role</p>
                        </div>
                        <a class="contact-action" href="tel:@contact.Phone">
                            <span class="bi bi-person-badge-fill" aria-hidden="true"></span>
                            @contact.Phone
                        </a>
                    </div>
                }
            </article>
        </div>
    </section>
</section>

@code {
    private SchoolConnect.Shared.Services.PortalSessionInfo? activeSession;
    private bool showAboutPopup;
    private bool showRoleAccessPopup;
    private bool showAdmissionPopup;
    private bool admissionPopupSubmitted;
    private string? admissionPopupMessage;
    private string roleAccessMessage = string.Empty;
    private readonly AdmissionPopupModel admissionPopup = new();

    protected override void OnInitialized()
    {
        PortalSession.Changed += HandleSessionChanged;
        activeSession = PortalSession.GetActiveSession();
    }

    private void HandleSessionChanged()
    {
        activeSession = PortalSession.GetActiveSession();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PortalSession.Changed -= HandleSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var activeSession = PortalSession.GetActiveSession();
        if (activeSession is not null)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("sessionStorage.setItem", PortalSessionService.BrowserSessionRoleKey, activeSession.Role);
            }
            catch
            {
                // Session storage is optional; the in-memory portal session still drives the UI.
            }

            return;
        }

        string? storedRole = null;
        try
        {
            storedRole = await JsRuntime.InvokeAsync<string?>("sessionStorage.getItem", PortalSessionService.BrowserSessionRoleKey);
        }
        catch
        {
            // Ignore storage access failures and continue with the current session state.
        }

        if (PortalSession.RestoreAuthenticatedRole(storedRole))
        {
            StateHasChanged();
        }
    }

    private void OpenAdmissionPopup()
    {
        showAdmissionPopup = true;
        admissionPopupSubmitted = false;
        admissionPopupMessage = null;
        admissionPopup.Reset();
    }

    private void CloseAdmissionPopup()
    {
        showAdmissionPopup = false;
    }

    private void OpenAboutPopup()
    {
        showAboutPopup = true;
    }

    private void CloseAboutPopup()
    {
        showAboutPopup = false;
    }

    private void OpenTeacherPortal()
    {
        if (PortalSession.GetActiveSession()?.Role == PortalRoles.Student)
        {
            roleAccessMessage = "Student users can't log in to the teacher portal. Please log out from the student portal before using teacher login.";
            showRoleAccessPopup = true;
            return;
        }

        if (PortalSession.GetActiveSession()?.Role == PortalRoles.Teacher)
        {
            Navigation.NavigateTo("/teacher-login");
            return;
        }

        Navigation.NavigateTo("/login?role=teacher");
    }

    private void OpenStudentPortal()
    {
        if (PortalSession.GetActiveSession()?.Role == PortalRoles.Teacher)
        {
            roleAccessMessage = "Teacher users can't log in to the student portal. Please log out from the teacher portal before using student login.";
            showRoleAccessPopup = true;
            return;
        }

        if (PortalSession.GetActiveSession()?.Role == PortalRoles.Student)
        {
            Navigation.NavigateTo("/student-login");
            return;
        }

        Navigation.NavigateTo("/login?role=student");
    }

    private void CloseRoleAccessPopup()
    {
        showRoleAccessPopup = false;
    }

    private void SubmitAdmissionPopup()
    {
        var school = Content.GetProfile();
        admissionPopupSubmitted = true;
        admissionPopupMessage = $"Thanks {admissionPopup.ParentName.Trim()}. {school.Name} will contact you about {admissionPopup.StudentName} on {admissionPopup.Mobile}.";
    }

    private sealed class AdmissionPopupModel
    {
        [Required(ErrorMessage = "Student name is required.")]
        public string StudentName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Parent or guardian name is required.")]
        public string ParentName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please select the class.")]
        public string ClassSeekingAdmission { get; set; } = string.Empty;

        [Required(ErrorMessage = "Mobile number is required.")]
        [Phone(ErrorMessage = "Enter a valid mobile number.")]
        public string Mobile { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email address is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please add enquiry details.")]
        [StringLength(250, ErrorMessage = "Details should stay within 250 characters.")]
        public string Details { get; set; } = string.Empty;

        public void Reset()
        {
            StudentName = string.Empty;
            ParentName = string.Empty;
            ClassSeekingAdmission = string.Empty;
            Mobile = string.Empty;
            Email = string.Empty;
            Details = string.Empty;
        }
    }
}
