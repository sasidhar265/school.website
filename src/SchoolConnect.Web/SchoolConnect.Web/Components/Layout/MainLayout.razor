@inherits LayoutComponentBase
@inject SchoolConnect.Shared.Services.SchoolContentService Content

@{
    var school = Content.GetProfile();
}

<div class="page">
    <NavMenu />

    <button id="language-toggle"
            class="language-toggle"
            type="button"
            aria-label="తెలుగుకు మార్చండి"
            title="తెలుగుకు మార్చండి">
        <span class="bi bi-translate" aria-hidden="true"></span>
        <span data-language-label>తెలుగు</span>
    </button>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
