<script type="module" src="Components/Layout/ReconnectModal.razor.js"></script>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="components-reconnect-container">
        <div class="svc-reconnect-brand" aria-hidden="true">
            <img src="_content/SchoolConnect.Shared/venkateswara-logo.svg" alt="" />
            <span>SVC</span>
        </div>
        <p class="svc-reconnect-school">Sri Venkateswara Convent</p>
        <div class="components-rejoining-animation" aria-hidden="true"><span></span></div>
        <p class="components-reconnect-first-attempt-visible">
            Preparing your school website...
        </p>
        <p class="components-reconnect-repeated-attempt-visible">
            The school website is starting. Trying again in <span id="components-seconds-to-next-attempt"></span> seconds.
        </p>
        <p class="components-reconnect-failed-visible">
            The school website is taking longer than expected to start.
        </p>
        <button id="components-reconnect-button" class="components-reconnect-failed-visible">
            Try again
        </button>
        <p class="components-pause-visible">
            Your school session is paused.
        </p>
        <button id="components-resume-button" class="components-pause-visible">
            Resume
        </button>
        <p class="components-resume-failed-visible">
            We could not resume your session. Please reload the page.
        </p>
        <p class="svc-reconnect-note">This page will open automatically when the service is ready.</p>
    </div>
</dialog>
