@implements IDisposable
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@inject SchoolConnect.Shared.Services.SchoolContentService Content
@inject SchoolConnect.Shared.Services.PortalSessionService PortalSession
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@{
    var school = Content.GetProfile();
    var hideLoginNav = ShouldHideLoginNav();
}

<header class="navbar navbar-expand-lg navbar-dark top-nav-shell">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/#top">
            <span class="brand-chip">@school.ShortName</span>
            <span>@school.Name</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#primaryNav" aria-controls="primaryNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="primaryNav">
            <nav class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#top" data-scrollspy-link="top">
                    <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/gallery">
                    <span class="bi bi-images" aria-hidden="true"></span> Gallery
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#why-choose-us" data-scrollspy-link="why-choose-us">
                    <span class="bi bi-patch-check-fill" aria-hidden="true"></span> Why Choose Us
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#latest-updates" data-scrollspy-link="latest-updates">
                    <span class="bi bi-megaphone-fill" aria-hidden="true"></span> Latest Updates
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#admissions" data-scrollspy-link="admissions">
                    <span class="bi bi-calendar-check-fill" aria-hidden="true"></span> Admissions
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#about-us" data-scrollspy-link="about-us">
                    <span class="bi bi-info-circle-fill" aria-hidden="true"></span> About Us
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#contacts" data-scrollspy-link="contacts">
                    <span class="bi bi-envelope-paper-fill" aria-hidden="true"></span> Contact Us
                </NavLink>

                @if (!hideLoginNav)
                {
                    <div class="nav-item dropdown login-profile-dropdown">
                        <button class="nav-link top-nav-link nav-item-pill login-profile-toggle dropdown-toggle" type="button" id="loginProfileMenu" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Open login options">
                            <span class="profile-icon bi bi-person-circle" aria-hidden="true"></span>
                            <span class="login-profile-label">@GetLoginDropdownLabel()</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end login-profile-menu" aria-labelledby="loginProfileMenu">
                            @if (activeSession is null)
                            {
                                <li>
                                    <NavLink class="dropdown-item login-profile-option" href="/login?role=student">
                                        <span class="login-option-icon bi bi-mortarboard-fill" aria-hidden="true"></span>
                                        Student Login
                                    </NavLink>
                                </li>
                                <li>
                                    <NavLink class="dropdown-item login-profile-option" href="/login?role=teacher">
                                        <span class="login-option-icon bi bi-person-workspace" aria-hidden="true"></span>
                                        Teacher Login
                                    </NavLink>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <button class="dropdown-item login-profile-option" type="button" @onclick="OpenProfilePopup">
                                        <span class="login-option-icon bi bi-person-badge-fill" aria-hidden="true"></span>
                                        Profile
                                    </button>
                                </li>
                                <li>
                                    <button class="dropdown-item login-profile-option" type="button" @onclick="OpenActivePortal">
                                        <span class="login-option-icon bi bi-box-arrow-up-right" aria-hidden="true"></span>
                                        Open Portal
                                    </button>
                                </li>
                                <li>
                                    <button class="dropdown-item login-profile-option" type="button" @onclick="LogoutActiveSession">
                                        <span class="login-option-icon bi bi-box-arrow-right" aria-hidden="true"></span>
                                        Sign out
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </nav>
        </div>
    </div>
</header>

@if (isProfilePopupOpen && activeSession is not null)
{
    <div class="timetable-popup-backdrop" role="presentation" @onclick="CloseProfilePopup">
        <div class="timetable-popup curriculum-popup student-profile-popup" role="dialog" aria-modal="true" aria-labelledby="nav-profile-popup-title" @onclick:stopPropagation="true">
            <div class="timetable-popup-header">
                <div>
                    <p class="eyebrow mb-1">@activeSession.RoleLabel Profile</p>
                    <h2 id="nav-profile-popup-title" class="mb-0">Profile details</h2>
                </div>
                <button type="button" class="timetable-popup-close" aria-label="Close profile" @onclick="CloseProfilePopup">x</button>
            </div>

            <div class="student-profile-popup-body">
                <div class="student-profile-summary">
                    <div class="student-profile-avatar student-profile-avatar-lg" aria-hidden="true">
                        @GetActiveSessionAvatar()
                    </div>
                    <div>
                        <p class="eyebrow mb-1">Logged in @activeSession.RoleLabel.ToLowerInvariant()</p>
                        <h3 class="mb-1">@activeSession.DisplayName</h3>
                        <p class="mb-0">@GetActiveSessionClassLine()</p>
                    </div>
                </div>

                <div class="curriculum-unit-list">
                    <article class="curriculum-unit-card">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                            <div>
                                <p class="eyebrow mb-1">Profile overview</p>
                                <h4 class="mb-2">@activeSession.RoleLabel details</h4>
                            </div>
                            <span class="badge rounded-pill text-bg-success">Active</span>
                        </div>
                        <div class="student-profile-detail-grid">
                            @if (activeSession.Role == SchoolConnect.Shared.Services.PortalRoles.Student)
                            {
                                <div><span>Student name</span><strong>@activeSession.DisplayName</strong></div>
                                <div><span>Class</span><strong>@GetValueOrFallback(activeSession.ClassName)</strong></div>
                                <div><span>Gender</span><strong>@GetValueOrFallback(activeSession.Gender)</strong></div>
                                <div><span>Parents / Guardian name</span><strong>@GetValueOrFallback(activeSession.GuardianName)</strong></div>
                                <div><span>Mobile phone number</span><strong>@GetValueOrFallback(activeSession.MobileNumber)</strong></div>
                                <div><span>Class teacher</span><strong>@GetValueOrFallback(activeSession.ClassTeacher)</strong></div>
                                <div><span>School joined year</span><strong>@GetValueOrFallback(activeSession.SchoolJoinedYear)</strong></div>
                            }
                            else
                            {
                                <div><span>Teacher name</span><strong>@activeSession.DisplayName</strong></div>
                                <div><span>Class dealing with</span><strong>@GetValueOrFallback(activeSession.ClassDealingWith)</strong></div>
                                <div><span>Subject</span><strong>@GetValueOrFallback(activeSession.Subject)</strong></div>
                                <div><span>Qualification</span><strong>@GetValueOrFallback(activeSession.Qualification)</strong></div>
                                <div><span>Gender</span><strong>@GetValueOrFallback(activeSession.Gender)</strong></div>
                            }
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private SchoolConnect.Shared.Services.PortalSessionInfo? activeSession;
    private bool shouldSyncScrollSpy = true;
    private bool shouldRestoreBrowserSession = true;
    private bool isProfilePopupOpen;

    protected override void OnInitialized()
    {
        PortalSession.Changed += HandleSessionChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        activeSession = PortalSession.GetActiveSession();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldRestoreBrowserSession && activeSession is null)
        {
            shouldRestoreBrowserSession = false;
            string? storedRole = null;
            try
            {
                storedRole = await JsRuntime.InvokeAsync<string?>("sessionStorage.getItem", SchoolConnect.Shared.Services.PortalSessionService.BrowserSessionRoleKey);
            }
            catch
            {
                // Session storage may be unavailable during prerender or in restricted browsers.
            }

            if (PortalSession.RestoreAuthenticatedRole(storedRole))
            {
                activeSession = PortalSession.GetActiveSession();
            }
        }

        if (shouldSyncScrollSpy)
        {
            shouldSyncScrollSpy = false;
            try
            {
                await JsRuntime.InvokeVoidAsync("schoolConnectScrollSpy.sync");
            }
            catch
            {
                // The helper script may not be available during very early loads.
            }
        }

        if (firstRender)
        {
            StateHasChanged();
        }
    }

    private void HandleSessionChanged()
    {
        activeSession = PortalSession.GetActiveSession();
        shouldRestoreBrowserSession = activeSession is null;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        shouldSyncScrollSpy = true;
        activeSession = PortalSession.GetActiveSession();
        shouldRestoreBrowserSession = activeSession is null;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PortalSession.Changed -= HandleSessionChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private async Task OpenActivePortal()
    {
        if (activeSession is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var target = activeSession.Role == SchoolConnect.Shared.Services.PortalRoles.Teacher
            ? "/teacher-login"
            : "/student-login";

        try
        {
            await JsRuntime.InvokeVoidAsync("sessionStorage.setItem", "schoolconnect.alreadyLoggedInNotice", activeSession.Role);
        }
        catch
        {
            // The target portal still opens even if browser storage is unavailable.
        }

        Navigation.NavigateTo(target);
    }

    private void OpenProfilePopup()
    {
        activeSession = PortalSession.GetActiveSession();
        if (activeSession is not null)
        {
            isProfilePopupOpen = true;
        }
    }

    private void CloseProfilePopup()
    {
        isProfilePopupOpen = false;
    }

    private string GetLoginDropdownLabel()
    {
        return string.IsNullOrWhiteSpace(activeSession?.DisplayName)
            ? "Login"
            : activeSession.DisplayName;
    }

    private async Task LogoutActiveSession()
    {
        if (activeSession is null)
        {
            return;
        }

        PortalSession.SignOut(activeSession.Role);

        try
        {
            await JsRuntime.InvokeVoidAsync("sessionStorage.removeItem", SchoolConnect.Shared.Services.PortalSessionService.BrowserSessionRoleKey);
            await JsRuntime.InvokeVoidAsync("sessionStorage.removeItem", "schoolconnect.alreadyLoggedInNotice");
        }
        catch
        {
            // Session storage is optional; the server-side session state has already been cleared.
        }

        activeSession = null;
        isProfilePopupOpen = false;
        shouldRestoreBrowserSession = false;
        Navigation.NavigateTo("/");
    }

    private string GetActiveSessionAvatar()
    {
        if (string.IsNullOrWhiteSpace(activeSession?.DisplayName))
        {
            return activeSession?.Role == SchoolConnect.Shared.Services.PortalRoles.Teacher ? "T" : "S";
        }

        return activeSession.DisplayName.Trim()[0].ToString().ToUpperInvariant();
    }

    private string GetActiveSessionClassLine()
    {
        if (activeSession is null)
        {
            return "Profile details";
        }

        if (activeSession.Role == SchoolConnect.Shared.Services.PortalRoles.Teacher)
        {
            return string.IsNullOrWhiteSpace(activeSession.ClassDealingWith)
                ? "Class dealing not assigned"
                : activeSession.ClassDealingWith;
        }

        return string.IsNullOrWhiteSpace(activeSession.ClassName)
            ? "Class not assigned"
            : activeSession.ClassName;
    }

    private static string GetValueOrFallback(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not assigned" : value;
    }

    private bool ShouldHideLoginNav()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
        return path is "login" or "student-login" or "teacher-login";
    }
}
