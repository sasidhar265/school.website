@implements IDisposable
@inject SchoolConnect.Shared.Services.SchoolContentService Content
@inject SchoolConnect.Shared.Services.PortalSessionService PortalSession
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@{
    var school = Content.GetProfile();
    var hideLoginNav = ShouldHideLoginNav();
}

<header class="navbar navbar-expand-lg navbar-dark top-nav-shell">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/#top">
            <span class="brand-chip">@school.ShortName</span>
            <span>@school.Name</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#primaryNav" aria-controls="primaryNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="primaryNav">
            <nav class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#top" data-scrollspy-link="top">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/gallery">
                    <span class="bi bi-images-nav-menu" aria-hidden="true"></span> Gallery
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#admissions" data-scrollspy-link="admissions">
                    <span class="bi bi-calendar-check-fill-nav-menu" aria-hidden="true"></span> Admissions
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#about-us" data-scrollspy-link="about-us">
                    <span class="bi bi-info-circle-fill-nav-menu" aria-hidden="true"></span> About Us
                </NavLink>

                <NavLink class="nav-link top-nav-link nav-item-pill" href="/#contacts" data-scrollspy-link="contacts">
                    <span class="bi bi-envelope-paper-fill-nav-menu" aria-hidden="true"></span> Contact Us
                </NavLink>

                @if (!hideLoginNav)
                {
                    @if (activeSession is null)
                    {
                        <div class="nav-item dropdown login-profile-dropdown">
                            <button class="nav-link top-nav-link nav-item-pill login-profile-toggle dropdown-toggle" type="button" id="loginProfileMenu" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Open login options">
                                <span class="profile-icon profile-icon-person" aria-hidden="true"></span>
                                <span class="login-profile-label">Login</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end login-profile-menu" aria-labelledby="loginProfileMenu">
                                <li>
                                    <NavLink class="dropdown-item login-profile-option" href="/login?role=student">
                                        <span class="login-option-icon" aria-hidden="true">S</span>
                                        Student Login
                                    </NavLink>
                                </li>
                                <li>
                                    <NavLink class="dropdown-item login-profile-option" href="/login?role=teacher">
                                        <span class="login-option-icon" aria-hidden="true">T</span>
                                        Teacher Login
                                    </NavLink>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <button class="nav-link top-nav-link nav-item-pill" type="button" title="@GetLoggedInLoginTitle()" @onclick="OpenActivePortal">
                            <span class="profile-icon" aria-hidden="true">@GetActiveSessionInitial()</span>
                            <span>@activeSession.RoleLabel</span>
                        </button>
                    }
                }
            </nav>
        </div>
    </div>
</header>

@code {
    private SchoolConnect.Shared.Services.PortalSessionInfo? activeSession;
    private bool shouldSyncScrollSpy = true;

    protected override void OnInitialized()
    {
        PortalSession.Changed += HandleSessionChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        activeSession = PortalSession.GetActiveSession();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && activeSession is null)
        {
            string? storedRole = null;
            try
            {
                storedRole = await JsRuntime.InvokeAsync<string?>("sessionStorage.getItem", SchoolConnect.Shared.Services.PortalSessionService.BrowserSessionRoleKey);
            }
            catch
            {
                // Session storage may be unavailable during prerender or in restricted browsers.
            }

            if (PortalSession.RestoreAuthenticatedRole(storedRole))
            {
                activeSession = PortalSession.GetActiveSession();
            }
        }

        if (shouldSyncScrollSpy)
        {
            shouldSyncScrollSpy = false;
            try
            {
                await JsRuntime.InvokeVoidAsync("schoolConnectScrollSpy.sync");
            }
            catch
            {
                // The helper script may not be available during very early loads.
            }
        }

        if (firstRender)
        {
            StateHasChanged();
        }
    }

    private void HandleSessionChanged()
    {
        activeSession = PortalSession.GetActiveSession();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        shouldSyncScrollSpy = true;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PortalSession.Changed -= HandleSessionChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private string GetLoggedInLoginTitle()
    {
        return activeSession is null ? "Login" : $"{activeSession.DisplayName} is already logged in";
    }

    private string GetActiveSessionInitial()
    {
        if (string.IsNullOrWhiteSpace(activeSession?.DisplayName))
        {
            return "P";
        }

        return activeSession.DisplayName.Trim()[0].ToString().ToUpperInvariant();
    }

    private async Task OpenActivePortal()
    {
        if (activeSession is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var target = activeSession.Role == SchoolConnect.Shared.Services.PortalRoles.Teacher
            ? "/teacher-login"
            : "/student-login";

        try
        {
            await JsRuntime.InvokeVoidAsync("sessionStorage.setItem", "schoolconnect.alreadyLoggedInNotice", activeSession.Role);
        }
        catch
        {
            // The target portal still opens even if browser storage is unavailable.
        }

        Navigation.NavigateTo(target);
    }

    private bool ShouldHideLoginNav()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
        return path is "login" or "student-login" or "teacher-login";
    }
}
