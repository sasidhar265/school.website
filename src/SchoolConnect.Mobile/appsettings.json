    "AboutUs": {
      "Title": "About Sri Venkateswara Convent",
      "Summary": "Sri Venkateswara Convent is a modern school platform for academics, communication, and administration with a reusable structure that can be adapted to another school by replacing configuration values.",
      "Highlights": [
        "Student and teacher portals on web and mobile",
        "Bootstrap-based interface with role-aware login",
        "Reusable configuration for school identity and content"
